#version 330

uniform mat4 mMatrix; 
uniform mat4 pMatrix = mat4(1.0);

uniform vec4 color = vec4(1.0f, 1.0f, 1.0f, 1.0f);

in vec2 pos2D;
in vec2 inTexCoord;


out vec4 InColor;
out vec2 TexCoord;

void main()
{
    gl_Position = pMatrix * mMatrix * vec4(pos2D.x, pos2D.y, 0.0, 1.0);
    InColor = color;       
    TexCoord = inTexCoord; 
}
